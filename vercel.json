{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "cleanUrls": true,
    "redirects": [
        { "source": "/services/", "destination": "/3D-Animation-Services", "permanent": true },
        { "source": "/services", "destination": "/3D-Animation-Services", "permanent": true }
    ],
    "rewrites": [
        { "source": "/3D-Animation-Services", "destination": "/services/" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src *; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data: blob:; media-src * blob:; frame-src *; connect-src *; font-src * data:;"
                }
            ]
        }
    ]
}